# ========================
# LaCuisine Backend - Variáveis de Ambiente
# ========================

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://lacuisine:lacuisine@localhost:5432/lacuisine

# Google Gemini API
GEMINI_API_KEY=your-gemini-api-key-here

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# CORS (separar múltiplas origens por vírgula)
ALLOWED_ORIGINS=["http://localhost:3000"]

# App
APP_NAME=LaCuisine API
DEBUG=true
